{
  "name": "dcv",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint:biome": "biome format --write ./src && biome lint --write ./src",
    "lint:eslint": "eslint ./src --fix",
    "lint": "bun run lint:biome && bun run lint:eslint"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "typescript": "6.0.2",
    "vite": "8.0.12",
    "@vitejs/plugin-react": "6.0.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/bun": "1.3.14",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "eslint-plugin-perfectionist": "5.9.1",
    "eslint": "9.39.1",
    "@biomejs/biome": "2.3.8"
  }
}
